{
  "extends": [
    "development"
  ],
  "hints": {
    "no-inline-styles": "off",
    "accessibility": "off",
    "hint-axe": "off",
    "html-validate": [
      "off",
      {
        "rules": {
          "valid-id": "off",
          "anchor-req-href": "off",
          "aria-hidden-body": "off",
          "aria-label": "off"
        }
      }
    ],
    "axe/name-role-value": "off",
    "disown-opener": "off",
    "axe/forms": "off"
  }
}